# ─────────────────────────────────────────────
# DocuSign Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# DocuSign App / Integration Key (from Apps & Keys in DocuSign Admin)
DS_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The DocuSign User GUID to impersonate (from Admin → Users)
DS_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your DocuSign Account ID (shown on Apps & Keys page)
DS_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RSA Private Key — use \n for newlines when setting in Render dashboard
# Example (single line):
# DS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIB...\n-----END RSA PRIVATE KEY-----"
DS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----"

# "demo" for sandbox, "production" for live
DS_ENVIRONMENT=demo

# Redirect URI registered in your DocuSign app (used for consent URL generation)
DS_REDIRECT_URI=https://your-app.onrender.com

# CORS — restrict to your frontend domain in production
ALLOWED_ORIGIN=https://your-app.onrender.com

# Port (Render sets this automatically; only needed for local dev)
PORT=3000
